{
  "title": "GamePanel Overview",
  "uid": "gamepanel-overview",
  "tags": ["gamepanel"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "timepicker": {
    "refresh_intervals": ["5s", "10s", "30s", "1m", "5m", "15m", "30m", "1h"]
  },
  "panels": [
    {
      "id": 1,
      "title": "API Status",
      "type": "stat",
      "gridPos": {"h": 3, "w": 4, "x": 0, "y": 0},
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "game_panel_api_up",
          "legendFormat": "",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          },
          "color": {
            "mode": "thresholds"
          }
        },
        "overrides": []
      }
    },
    {
      "id": 2,
      "title": "Daemon Status",
      "type": "stat",
      "gridPos": {"h": 3, "w": 4, "x": 4, "y": 0},
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "game_panel_daemon_runtime_enabled",
          "legendFormat": "",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          },
          "color": {
            "mode": "thresholds"
          }
        },
        "overrides": []
      }
    },
    {
      "id": 3,
      "title": "Connected Nodes",
      "type": "stat",
      "gridPos": {"h": 3, "w": 4, "x": 8, "y": 0},
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "count(up{job=\"daemon\"} == 1)",
          "legendFormat": "",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "orange", "value": 1 },
              { "color": "green", "value": 2 }
            ]
          },
          "color": {
            "mode": "thresholds"
          }
        },
        "overrides": []
      }
    },
    {
      "id": 4,
      "title": "API Uptime",
      "type": "stat",
      "gridPos": {"h": 3, "w": 6, "x": 0, "y": 3},
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "game_panel_api_uptime_seconds",
          "legendFormat": "",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": {
            "mode": "none"
          }
        },
        "overrides": []
      }
    },
    {
      "id": 5,
      "title": "Daemon Uptime",
      "type": "stat",
      "gridPos": {"h": 3, "w": 6, "x": 6, "y": 3},
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "game_panel_daemon_uptime_seconds",
          "legendFormat": "",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": {
            "mode": "none"
          }
        },
        "overrides": []
      }
    },
    {
      "id": 6,
      "title": "Request Rate",
      "type": "timeseries",
      "gridPos": {"h": 6, "w": 6, "x": 0, "y": 6},
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "sum(rate(request_latency_seconds_count[5m]))",
          "legendFormat": "All",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": {
            "mode": "palette-classic"
          }
        },
        "overrides": []
      }
    },
    {
      "id": 7,
      "title": "Latency p50",
      "type": "timeseries",
      "gridPos": {"h": 6, "w": 6, "x": 6, "y": 6},
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(request_latency_seconds_bucket[5m])) by (le))",
          "legendFormat": "p50",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": {
            "mode": "palette-classic"
          }
        },
        "overrides": []
      }
    },
    {
      "id": 8,
      "title": "Latency p95 / p99",
      "type": "timeseries",
      "gridPos": {"h": 6, "w": 6, "x": 0, "y": 12},
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(request_latency_seconds_bucket[5m])) by (le))",
          "legendFormat": "p95",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(request_latency_seconds_bucket[5m])) by (le))",
          "legendFormat": "p99",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": {
            "mode": "palette-classic"
          }
        },
        "overrides": []
      }
    },
    {
      "id": 9,
      "title": "Error Rate",
      "type": "timeseries",
      "gridPos": {"h": 6, "w": 6, "x": 6, "y": 12},
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "rate(request_latency_seconds_count{path=~\".*error.*|.*fail.*\"}[5m]) or vector(0)",
          "legendFormat": "Errors",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": {
            "mode": "palette-classic"
          }
        },
        "overrides": []
      }
    },
    {
      "id": 10,
      "title": "Total Servers",
      "type": "stat",
      "gridPos": {"h": 3, "w": 4, "x": 0, "y": 18},
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "sum(server_status)",
          "legendFormat": "",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "color": {
            "mode": "none"
          }
        },
        "overrides": []
      }
    },
    {
      "id": 11,
      "title": "Servers by Status",
      "type": "stat",
      "gridPos": {"h": 3, "w": 8, "x": 4, "y": 18},
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "sum(server_status{status=\"running\"})",
          "legendFormat": "Running",
          "refId": "A"
        },
        {
          "expr": "sum(server_status{status=\"stopped\"})",
          "legendFormat": "Stopped",
          "refId": "B"
        },
        {
          "expr": "sum(server_status{status=\"installing\"})",
          "legendFormat": "Installing",
          "refId": "C"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "color": {
            "mode": "palette-classic"
          }
        },
        "overrides": []
      }
    },
    {
      "id": 12,
      "title": "API Memory Usage",
      "type": "timeseries",
      "gridPos": {"h": 6, "w": 12, "x": 0, "y": 21},
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "game_panel_api_memory_alloc_bytes",
          "legendFormat": "API",
          "refId": "A"
        },
        {
          "expr": "game_panel_daemon_memory_alloc_bytes",
          "legendFormat": "Daemon",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "color": {
            "mode": "palette-classic"
          }
        },
        "overrides": []
      }
    },
    {
      "id": 13,
      "title": "Goroutines",
      "type": "timeseries",
      "gridPos": {"h": 6, "w": 12, "x": 0, "y": 27},
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "game_panel_api_goroutines",
          "legendFormat": "API",
          "refId": "A"
        },
        {
          "expr": "game_panel_daemon_goroutines",
          "legendFormat": "Daemon",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "color": {
            "mode": "palette-classic"
          }
        },
        "overrides": []
      }
    },
    {
      "id": 14,
      "title": "Online Nodes",
      "type": "stat",
      "gridPos": {"h": 3, "w": 4, "x": 0, "y": 33},
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "count(up{job=\"daemon\"} == 1)",
          "legendFormat": "",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          },
          "color": {
            "mode": "thresholds"
          }
        },
        "overrides": []
      }
    },
    {
      "id": 15,
      "title": "Offline Nodes",
      "type": "stat",
      "gridPos": {"h": 3, "w": 4, "x": 4, "y": 33},
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "count(up{job=\"daemon\"} == 0)",
          "legendFormat": "",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          },
          "color": {
            "mode": "thresholds"
          }
        },
        "overrides": []
      }
    },
    {
      "id": 16,
      "title": "Node Memory (Daemon)",
      "type": "gauge",
      "gridPos": {"h": 6, "w": 4, "x": 8, "y": 33},
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "game_panel_daemon_memory_alloc_bytes",
          "legendFormat": "{{instance}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 524288000 },
              { "color": "red", "value": 1073741824 }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 17,
      "title": "Node CPU (Goroutines)",
      "type": "gauge",
      "gridPos": {"h": 6, "w": 4, "x": 8, "y": 39},
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "game_panel_daemon_goroutines",
          "legendFormat": "{{instance}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 100 },
              { "color": "red", "value": 500 }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 18,
      "title": "Backup Duration",
      "type": "timeseries",
      "gridPos": {"h": 6, "w": 6, "x": 0, "y": 45},
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "rate(backup_duration_seconds_sum[5m]) / rate(backup_duration_seconds_count[5m])",
          "legendFormat": "Avg Duration",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": {
            "mode": "palette-classic"
          }
        },
        "overrides": []
      }
    },
    {
      "id": 19,
      "title": "Backup Rate",
      "type": "timeseries",
      "gridPos": {"h": 6, "w": 6, "x": 6, "y": 45},
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "rate(backup_duration_seconds_count[5m])",
          "legendFormat": "Backups/s",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "color": {
            "mode": "palette-classic"
          }
        },
        "overrides": []
      }
    },
    {
      "id": 20,
      "title": "Backup Success / Failure",
      "type": "stat",
      "gridPos": {"h": 3, "w": 4, "x": 0, "y": 51},
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "sum(rate(backup_duration_seconds_count[24h]))",
          "legendFormat": "Total (24h)",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "color": {
            "mode": "none"
          }
        },
        "overrides": []
      }
    },
    {
      "id": 21,
      "title": "Postgres Backup Age",
      "type": "timeseries",
      "gridPos": {"h": 3, "w": 8, "x": 4, "y": 51},
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "time() - game_panel_api_uptime_seconds",
          "legendFormat": "Process Age",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": {
            "mode": "palette-classic"
          }
        },
        "overrides": []
      }
    }
  ]
}
